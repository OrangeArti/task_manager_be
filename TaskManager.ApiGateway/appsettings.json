{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Gateway": {
    "Cors": {
      "AllowedOrigins": [
        "http://localhost:3000",
        "http://localhost:5173"
      ]
    },
    "Auth": {
      "Username": "frontend",
      "Password": "frontend-secret"
    },
    "Services": {
      "tasks": {
        "Name": "tasks-service",
        "BaseUrl": "http://tasks-service:8080",
        "HealthPath": "/health"
      },
      "teams": {
        "Name": "teams-service",
        "BaseUrl": "http://teams-service:8080",
        "HealthPath": "/health"
      },
      "users": {
        "Name": "users-service",
        "BaseUrl": "http://users-service:8080",
        "HealthPath": "/health"
      }
    }
  }
}
