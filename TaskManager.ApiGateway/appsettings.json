{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Gateway": {
    "Cors": {
      "AllowedOrigins": [
        "http://localhost:4200",
        "http://127.0.0.1:4200"
      ]
    },
    "Services": {
      "tasks": {
        "Name": "tasks-service",
        "BaseUrl": "http://tasks-service:8080",
        "ForwardPath": "/api/tasks",
        "HealthPath": "/health"
      },
      "teams": {
        "Name": "teams-service",
        "BaseUrl": "http://teams-service:8080",
        "ForwardPath": "/teams",
        "HealthPath": "/health"
      },
      "users": {
        "Name": "users-service",
        "BaseUrl": "http://users-service:8080",
        "ForwardPath": "/users",
        "HealthPath": "/health"
      },
      "auth": {
        "Name": "auth-service",
        "BaseUrl": "http://tasks-service:8080",
        "ForwardPath": "/api/auth",
        "HealthPath": "/health"
      }
    }
  },
  "ReverseProxy": {
    "Routes": {
      "tasks-route": {
        "ClusterId": "tasks-cluster",
        "Match": {
          "Path": "/api/tasks/{**catch-all}"
        }
      },
      "teams-route": {
        "ClusterId": "teams-cluster",
        "Match": {
          "Path": "/api/teams/{**catch-all}"
        }
      },
      "users-route": {
        "ClusterId": "users-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "tasks-cluster": {
        "Destinations": {
          "tasks-dest": {
            "Address": "http://tasks-service:8080/"
          }
        }
      },
      "teams-cluster": {
        "Destinations": {
          "teams-dest": {
            "Address": "http://teams-service:8080/"
          }
        }
      },
      "users-cluster": {
        "Destinations": {
          "users-dest": {
            "Address": "http://users-service:8080/"
          }
        }
      }
    }
  }
}