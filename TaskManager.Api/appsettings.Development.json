{
  "DisableHttps": true,
  "AllowedCorsOrigins": [
    "http://localhost:4200",
    "https://localhost:4200"
  ],

  "Keycloak": {
    "realm": "task-manager",
    "auth-server-url": "http://localhost:8180",
    "ssl-required": "none",
    "resource": "task-manager-frontend",
    "verify-token-audience": false
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
